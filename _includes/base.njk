<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>{{ title or "Resilience Orbit" }}</title>
  <meta name="description" content="{{ description or 'Resilience engineering playbooks for technology leaders' }}"/>

  <meta property="og:type" content="article"/>
  <meta property="og:title" content="{{ ogTitle or title }}"/>
  <meta property="og:description" content="{{ ogDescription or description }}"/>
  <meta property="og:url" content="https://resilienceorbit.com{{ page.url or '/' }}"/>
  <meta property="og:image" content="{{ ogImage or '/assets/og-default.png' }}"/>
  <meta name="twitter:card" content="summary_large_image"/>

  <link rel="alternate" type="application/rss+xml" title="Resilience Orbit RSS" href="/blog/rss.xml"/>
  <link rel="sitemap" type="application/xml" href="/sitemap.xml"/>
  <link rel="icon" href="/favicon.ico">
  <link rel="stylesheet" href="/assets/site.css"/>

  <style>
    :root { --bg:#0B1020; --panel:#0F172A; --ink:#E5E7EB; --muted:#94A3B8; --brand:#6366F1; --brand2:#22D3EE; --stroke:rgba(255,255,255,.12); --stroke2:rgba(255,255,255,.18); }
    body { margin:0; font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial; color:var(--ink); background:#0B1020; }
    .container { max-width:1100px; margin:0 auto; padding:24px 16px; }
    a { color:inherit; text-decoration:none; }
    nav a { font-weight:600; }
    header { padding: 32px 0 12px; }
    footer { padding:22px; text-align:center; color:var(--muted); font-size:13px; }
  </style>
</head>

<body>
  <header class="container">
    <nav style="display:flex;gap:14px;flex-wrap:wrap;font-size:14px;">
      <a href="/">Home</a>
      <a href="/framework/">Framework</a>
      <a href="/about/">About</a>
      <a href="/blog/">Blog</a>
      <a class="badge" href="/blog/rss.xml" style="padding:6px 10px;border-radius:999px;border:1px solid var(--stroke2);background:rgba(255,255,255,.06);">RSS</a>
    </nav>
  </header>

  <main class="container">
    {{ content | safe }}
  </main>

  <footer>
    © 2026 Resilience Orbit™.
    <a href="/about/">About</a> • <a href="/framework/">Framework</a> • <a href="/blog/">Blog</a>
  </footer>
</body>
</html>
