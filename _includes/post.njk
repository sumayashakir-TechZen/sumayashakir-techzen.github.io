---
layout: base.njk
---
<article>
  <h1>{{ title }}</h1>
  <p class="muted">{{ date }}</p>
  <div class="post-body">
    {{ content | safe }}
  </div>

  {% if tags and tags.length %}
  <p class="tags">Tags:
    {% for t in tags %}
      <a href="/blog/tags/{{ t | url }}/">{{ t }}</a>{% if not loop.last %}, {% endif %}
    {% endfor %}
  </p>
  {% endif %}

  <hr/>
  <p><a href="/blog/">← Back to all posts</a></p>
</article>
